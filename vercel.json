{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client",
        "buildCommand": "npm run build"
      }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/donations/mpesa.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/donations/(.*)", "dest": "/api/donations/$1" },
    { "src": "/sitemap\\.xml", "dest": "/api/server.js" },
    { "src": "(.*)", "dest": "/api/server.js" }
  ]
}
